<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <import type="android.view.View" />

        <import type="org.amnezia.awg.model.ObservableTunnel" />

        <import type="org.amnezia.awg.model.ObservableTunnel.ConnectionStatus" />

        <import type="org.amnezia.awg.backend.Tunnel.State" />

        <variable
            name="collection"
            type="org.amnezia.awg.databinding.ObservableKeyedArrayList&lt;String, ObservableTunnel&gt;" />

        <variable
            name="key"
            type="String" />

        <variable
            name="item"
            type="org.amnezia.awg.model.ObservableTunnel" />

        <variable
            name="fragment"
            type="org.amnezia.awg.fragment.TunnelListFragment" />
    </data>

    <org.amnezia.awg.widget.MultiselectableRelativeLayout
        android:id="@+id/tunnel_list_item"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/transparent"
        android:descendantFocusability="beforeDescendants"
        android:focusable="true"
        android:paddingTop="4dp"
        android:paddingBottom="20dp">

        <LinearLayout
            android:id="@+id/cif_root_panel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cif_status_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="18dp"
                app:cardBackgroundColor="#101B33"
                app:cardCornerRadius="30dp"
                app:cardElevation="0dp"
                app:strokeColor="#213E73"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="22dp"
                    android:paddingTop="22dp"
                    android:paddingEnd="22dp"
                    android:paddingBottom="22dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/cif_mode_pill"
                        android:letterSpacing="0.08"
                        android:paddingStart="14dp"
                        android:paddingTop="7dp"
                        android:paddingEnd="14dp"
                        android:paddingBottom="7dp"
                        android:text="@string/cif_tunnel_mode"
                        android:textAllCaps="true"
                        android:textColor="#8EF7FF"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tunnel_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="@{key}"
                        android:textColor="#FFFFFFFF"
                        android:textSize="27sp"
                        android:textStyle="bold"
                        tools:text="amnezia_for_awg" />

                    <TextView
                        android:id="@+id/tunnel_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@{item.connectionStatus == ConnectionStatus.CONNECTED ? @string/cif_status_connected : item.connectionStatus == ConnectionStatus.CONNECTING ? @string/cif_status_connecting : @string/cif_status_disconnected}"
                        android:textColor="@{item.connectionStatus == ConnectionStatus.CONNECTED ? @color/tunnel_status_connected : item.connectionStatus == ConnectionStatus.CONNECTING ? @color/tunnel_status_connecting : @color/cif_muted_text}"
                        android:textSize="17sp"
                        tools:text="Защита включена" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <FrameLayout
                android:id="@+id/power_button"
                android:layout_width="254dp"
                android:layout_height="254dp"
                android:layout_marginTop="10dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless">

                <View
                    android:id="@+id/power_glow"
                    android:layout_width="254dp"
                    android:layout_height="254dp"
                    android:layout_gravity="center"
                    android:alpha="@{item.state == State.UP ? 0.95f : 0.38f}"
                    android:background="@drawable/cif_power_glow" />

                <View
                    android:id="@+id/power_ring"
                    android:layout_width="224dp"
                    android:layout_height="224dp"
                    android:layout_gravity="center"
                    android:background="@{item.state == State.UP ? @drawable/cif_power_ring_on : @drawable/cif_power_ring_off}" />

                <TextView
                    android:layout_width="102dp"
                    android:layout_height="102dp"
                    android:layout_gravity="center"
                    android:background="@{item.state == State.UP ? @drawable/cif_power_core_on : @drawable/cif_power_core_off}"
                    android:gravity="center"
                    android:text="⏻"
                    android:textColor="#FFFFFFFF"
                    android:textSize="50sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <TextView
                android:id="@+id/power_hint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:text="@{item.state == State.UP ? @string/cif_power_hint_on : @string/cif_power_hint_off}"
                android:textColor="#B7C7E6"
                android:textSize="16sp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/split_tunneling_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="#13213F"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeColor="#1F74FF"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="18dp"
                    android:paddingTop="16dp"
                    android:paddingEnd="18dp"
                    android:paddingBottom="16dp">

                    <TextView
                        android:layout_width="46dp"
                        android:layout_height="46dp"
                        android:background="@drawable/cif_split_icon_bg"
                        android:gravity="center"
                        android:text="⇄"
                        android:textColor="#FFFFFF"
                        android:textSize="26sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/cif_split_tunneling"
                            android:textColor="#FFFFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/cif_split_tunneling_subtitle"
                            android:textColor="#91A4C6"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textColor="#DDE8FF"
                        android:textSize="34sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <org.amnezia.awg.widget.ToggleSwitch
                android:id="@+id/tunnel_switch"
                android:layout_width="1dp"
                android:layout_height="1dp"
                android:alpha="0"
                android:clickable="false"
                android:focusable="false"
                app:checked="@{item.state == State.UP}"
                app:onBeforeCheckedChanged="@{fragment::setTunnelState}" />

        </LinearLayout>
    </org.amnezia.awg.widget.MultiselectableRelativeLayout>
</layout>
