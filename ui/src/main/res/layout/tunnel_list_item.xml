<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <import type="org.amnezia.awg.model.ObservableTunnel" />
        <import type="org.amnezia.awg.model.ObservableTunnel.ConnectionStatus" />
        <import type="org.amnezia.awg.backend.Tunnel.State" />

        <variable name="collection" type="org.amnezia.awg.databinding.ObservableKeyedArrayList&lt;String, ObservableTunnel&gt;" />
        <variable name="key" type="String" />
        <variable name="item" type="org.amnezia.awg.model.ObservableTunnel" />
        <variable name="fragment" type="org.amnezia.awg.fragment.TunnelListFragment" />
    </data>

    <org.amnezia.awg.widget.MultiselectableRelativeLayout
        android:id="@+id/tunnel_list_item"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/transparent"
        android:descendantFocusability="beforeDescendants"
        android:focusable="true"
        android:paddingBottom="18dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingTop="4dp"
                android:paddingBottom="14dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/cif_app_name"
                    android:textColor="#FFFFFFFF"
                    android:textSize="30sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/cif_status_chip_bg"
                    android:paddingStart="13dp"
                    android:paddingTop="7dp"
                    android:paddingEnd="13dp"
                    android:paddingBottom="7dp"
                    android:text="@{item.connectionStatus == ConnectionStatus.CONNECTING ? @string/cif_status_connecting_short : item.state == State.UP ? @string/cif_status_connected_short : @string/cif_status_off_short}"
                    android:textColor="@{item.connectionStatus == ConnectionStatus.CONNECTING ? @color/cif_warning : item.state == State.UP ? @color/cif_success : @color/cif_muted_text}"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    tools:text="ЗАЩИЩЕНО" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="18dp"
                app:cardBackgroundColor="#B8142034"
                app:cardCornerRadius="26dp"
                app:cardElevation="0dp"
                app:strokeColor="#263A59"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="20dp"
                    android:paddingTop="17dp"
                    android:paddingEnd="20dp"
                    android:paddingBottom="17dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/cif_profile_title"
                        android:textColor="#7F8EA8"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tunnel_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="@{key}"
                        android:textColor="#FFFFFFFF"
                        android:textSize="21sp"
                        android:textStyle="bold"
                        tools:text="amnezia_for_awg" />

                    <TextView
                        android:id="@+id/tunnel_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@{item.connectionStatus == ConnectionStatus.CONNECTING ? @string/cif_status_connecting : item.state == State.UP ? @string/cif_status_connected : @string/cif_status_disconnected}"
                        android:textColor="#A8B5CA"
                        android:textSize="14sp"
                        tools:text="VPN включён. Соединение защищено." />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <Space
                android:layout_width="1dp"
                android:layout_height="0dp"
                android:layout_weight="0.28" />

            <org.amnezia.awg.widget.CifVpnPowerView
                android:id="@+id/power_button"
                android:layout_width="236dp"
                android:layout_height="236dp"
                app:connectionStatus="@{item.connectionStatus}"
                app:vpnState="@{item.state}" />

            <TextView
                android:id="@+id/power_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:gravity="center"
                android:text="@{item.connectionStatus == ConnectionStatus.CONNECTING ? @string/cif_power_hint_connecting : item.state == State.UP ? @string/cif_power_hint_on : @string/cif_power_hint_off}"
                android:textColor="#C1CEE2"
                android:textSize="16sp"
                tools:text="Нажмите, чтобы отключить" />

            <Space
                android:layout_width="1dp"
                android:layout_height="0dp"
                android:layout_weight="0.42" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/whitelist_button"
                android:layout_width="match_parent"
                android:layout_height="78dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="#B8142034"
                app:cardCornerRadius="23dp"
                app:cardElevation="0dp"
                app:strokeColor="#294361"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/cif_smart_bypass_title"
                            android:textColor="#FFFFFFFF"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="@string/cif_smart_bypass_subtitle"
                            android:textColor="#8FA0B8"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textColor="#D4E8FF"
                        android:textSize="30sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/import_button"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="11dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="#80101928"
                app:cardCornerRadius="21dp"
                app:cardElevation="0dp"
                app:strokeColor="#1F3048"
                app:strokeWidth="1dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="@string/cif_action_import"
                    android:textColor="#D7E3F4"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </org.amnezia.awg.widget.MultiselectableRelativeLayout>
</layout>
