<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <import type="org.amnezia.awg.model.ObservableTunnel" />

        <import type="org.amnezia.awg.model.ObservableTunnel.ConnectionStatus" />

        <import type="org.amnezia.awg.backend.Tunnel.State" />

        <variable
            name="collection"
            type="org.amnezia.awg.databinding.ObservableKeyedArrayList&lt;String, ObservableTunnel&gt;" />

        <variable
            name="key"
            type="String" />

        <variable
            name="item"
            type="org.amnezia.awg.model.ObservableTunnel" />

        <variable
            name="fragment"
            type="org.amnezia.awg.fragment.TunnelListFragment" />
    </data>

    <org.amnezia.awg.widget.MultiselectableRelativeLayout
        android:id="@+id/tunnel_list_item"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        android:descendantFocusability="beforeDescendants"
        android:focusable="true"
        android:nextFocusRight="@+id/tunnel_switch"
        android:paddingTop="6dp"
        android:paddingBottom="6dp">

        <LinearLayout
            android:id="@+id/cif_vpn_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/cif_vpn_card_bg"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingStart="22dp"
            android:paddingTop="28dp"
            android:paddingEnd="22dp"
            android:paddingBottom="28dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/smartroute_app_name"
                android:textColor="#FFFFFF"
                android:textSize="34sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tunnel_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/cif_vpn_status_pill"
                android:paddingStart="14dp"
                android:paddingTop="7dp"
                android:paddingEnd="14dp"
                android:paddingBottom="7dp"
                android:text="@{item.state == State.UP ? @string/cif_vpn_connected : @string/cif_vpn_ready}"
                android:textAllCaps="true"
                android:textColor="@{item.state == State.UP ? @color/tunnel_status_connected : @color/tunnel_status_connecting}"
                android:textSize="12sp"
                android:textStyle="bold"
                tools:text="ГОТОВ К ПОДКЛЮЧЕНИЮ" />

            <FrameLayout
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:layout_marginTop="30dp"
                android:layout_marginBottom="28dp">

                <FrameLayout
                    android:layout_width="196dp"
                    android:layout_height="196dp"
                    android:layout_gravity="center"
                    android:background="@drawable/cif_power_button_bg">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="⏻"
                        android:textColor="#FFFFFF"
                        android:textSize="72sp"
                        android:textStyle="bold" />
                </FrameLayout>

                <org.amnezia.awg.widget.ToggleSwitch
                    android:id="@+id/tunnel_switch"
                    android:layout_width="220dp"
                    android:layout_height="220dp"
                    android:layout_gravity="center"
                    android:alpha="0.01"
                    android:nextFocusLeft="@+id/tunnel_list_item"
                    app:checked="@{item.state == State.UP}"
                    app:onBeforeCheckedChanged="@{fragment::setTunnelState}"
                    tools:checked="false" />
            </FrameLayout>

            <TextView
                android:id="@+id/tunnel_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="1"
                android:text="@{key}"
                android:textColor="#E5E7EB"
                android:textSize="22sp"
                android:textStyle="bold"
                tools:text="cif_vpn" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="@{item.state == State.UP ? @string/cif_vpn_tap_to_disconnect : @string/cif_vpn_tap_to_connect}"
                android:textColor="#98A2B3"
                android:textSize="15sp" />
        </LinearLayout>
    </org.amnezia.awg.widget.MultiselectableRelativeLayout>
</layout>
