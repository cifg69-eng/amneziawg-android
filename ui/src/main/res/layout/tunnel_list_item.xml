<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <import type="org.amnezia.awg.model.ObservableTunnel" />
        <import type="org.amnezia.awg.model.ObservableTunnel.ConnectionStatus" />
        <import type="org.amnezia.awg.backend.Tunnel.State" />

        <variable
            name="collection"
            type="org.amnezia.awg.databinding.ObservableKeyedArrayList&lt;String, ObservableTunnel&gt;" />

        <variable
            name="key"
            type="String" />

        <variable
            name="item"
            type="org.amnezia.awg.model.ObservableTunnel" />

        <variable
            name="fragment"
            type="org.amnezia.awg.fragment.TunnelListFragment" />
    </data>

    <org.amnezia.awg.widget.MultiselectableRelativeLayout
        android:id="@+id/tunnel_list_item"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/transparent"
        android:descendantFocusability="beforeDescendants"
        android:focusable="true"
        android:paddingBottom="18dp">

        <LinearLayout
            android:id="@+id/cif_root_panel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/cif_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingTop="4dp"
                android:paddingBottom="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/cif_app_name"
                    android:textColor="#FFFFFFFF"
                    android:textSize="30sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/status_chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/cif_clean_chip_bg"
                    android:paddingStart="14dp"
                    android:paddingTop="8dp"
                    android:paddingEnd="14dp"
                    android:paddingBottom="8dp"
                    android:text="@{item.connectionStatus == ConnectionStatus.CONNECTING ? @string/cif_status_connecting_short : item.state == State.UP ? @string/cif_status_connected_short : @string/cif_status_off_short}"
                    android:textColor="@{item.connectionStatus == ConnectionStatus.CONNECTING ? @color/cif_warning : item.state == State.UP ? @color/cif_success : @color/cif_muted_text}"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    tools:text="ЗАЩИЩЕНО" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cif_profile_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="28dp"
                app:cardBackgroundColor="#121B2A"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                app:strokeColor="#223049"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="20dp"
                    android:paddingTop="18dp"
                    android:paddingEnd="20dp"
                    android:paddingBottom="18dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/cif_profile_title"
                        android:textColor="#7F8EA8"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tunnel_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="@{key}"
                        android:textColor="#FFFFFFFF"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        tools:text="amnezia_for_awg" />

                    <TextView
                        android:id="@+id/tunnel_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="7dp"
                        android:text="@{item.connectionStatus == ConnectionStatus.CONNECTING ? @string/cif_status_connecting : item.state == State.UP ? @string/cif_status_connected : @string/cif_status_disconnected}"
                        android:textColor="#A8B5CA"
                        android:textSize="15sp"
                        tools:text="VPN включён. Соединение защищено." />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <Space
                android:layout_width="1dp"
                android:layout_height="0dp"
                android:layout_weight="0.25" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/power_button"
                android:layout_width="214dp"
                android:layout_height="214dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                app:cardBackgroundColor="#101827"
                app:cardCornerRadius="107dp"
                app:cardElevation="12dp"
                app:strokeColor="#2D3B55"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/cif_clean_power_bg"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/power_state_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@{item.connectionStatus == ConnectionStatus.CONNECTING ? @string/cif_button_connecting : item.state == State.UP ? @string/cif_button_on : @string/cif_button_off}"
                        android:textColor="@{item.connectionStatus == ConnectionStatus.CONNECTING ? @color/cif_warning : item.state == State.UP ? @color/cif_success : @color/cif_button_off_text}"
                        android:textSize="34sp"
                        android:textStyle="bold"
                        tools:text="ON" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/cif_button_caption"
                        android:textColor="#8390A7"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/power_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:text="@{item.connectionStatus == ConnectionStatus.CONNECTING ? @string/cif_power_hint_connecting : item.state == State.UP ? @string/cif_power_hint_on : @string/cif_power_hint_off}"
                android:textColor="#BCC7DA"
                android:textSize="16sp"
                tools:text="Нажмите, чтобы отключить" />

            <Space
                android:layout_width="1dp"
                android:layout_height="0dp"
                android:layout_weight="0.5" />

            <LinearLayout
                android:id="@+id/cif_actions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/whitelist_button"
                    android:layout_width="match_parent"
                    android:layout_height="74dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="#121B2A"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#26354E"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/cif_action_whitelist"
                                android:textColor="#FFFFFFFF"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="3dp"
                                android:text="@string/cif_action_whitelist_subtitle"
                                android:textColor="#8C9AAF"
                                android:textSize="13sp" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textColor="#CBD6EA"
                            android:textSize="30sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/import_button"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginTop="12dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="#0F1624"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#202D42"
                    app:strokeWidth="1dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="@string/cif_action_import"
                        android:textColor="#D8E2F2"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </LinearLayout>
    </org.amnezia.awg.widget.MultiselectableRelativeLayout>
</layout>
